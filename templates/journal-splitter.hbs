<div class="jss-container">

    {{!-- Header --}}
    <div class="jss-header">
        <h2><i class="fas fa-cut"></i> Journal Splitter</h2>
        <p>Separar headings em páginas individuais</p>
    </div>

    {{!-- Body --}}
    <div class="jss-body">

        {{!-- Left Panel: Journal & Pages --}}
        <div class="jss-left">
            <div class="jss-section-label"><i class="fas fa-book"></i> Journal</div>
            <select class="jss-journal-select js-journal-select">
                <option value="">— Escolha um journal —</option>
                {{#each journals}}
                <option value="{{this.id}}">{{this.name}}</option>
                {{/each}}
            </select>

            <div class="jss-section-label"><i class="fas fa-file-alt"></i> Páginas ({{pageCount}})</div>
            <div class="jss-page-scroll">
                {{#if hasSelection}}
                    {{#each pages}}
                    <div class="jss-page-item">
                        <i class="fas {{#if this.isText}}fa-file-alt{{else}}fa-cube{{/if}}"></i>
                        <span class="jss-page-name">{{this.name}}</span>
                    </div>
                    {{/each}}
                {{else}}
                    <div class="jss-empty">Selecione um journal acima</div>
                {{/if}}
            </div>
        </div>

        {{!-- Right Panel: Config --}}
        <div class="jss-right">
            <div class="jss-section-label"><i class="fas fa-cog"></i> Headings → Levels</div>

            {{!-- H1 --}}
            <div class="jss-heading-row">
                <span class="jss-badge jss-b1">H1</span>
                <div class="jss-heading-info">
                    <div class="jss-heading-title">Heading 1</div>
                    <div class="jss-heading-sub">Vira nova página com este level</div>
                </div>
                <select class="jss-level-select js-h1-level">
                    {{#each ../levelOptions}}
                    <option value="{{this.value}}" {{#if (eq this.value ../h1Level)}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                </select>
            </div>

            {{!-- H2 --}}
            <div class="jss-heading-row">
                <span class="jss-badge jss-b2">H2</span>
                <div class="jss-heading-info">
                    <div class="jss-heading-title">Heading 2</div>
                    <div class="jss-heading-sub">Vira nova página com este level</div>
                </div>
                <select class="jss-level-select js-h2-level">
                    {{#each ../levelOptions}}
                    <option value="{{this.value}}" {{#if (eq this.value ../h2Level)}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                </select>
            </div>

            {{!-- H3 --}}
            <div class="jss-heading-row">
                <span class="jss-badge jss-b3">H3</span>
                <div class="jss-heading-info">
                    <div class="jss-heading-title">Heading 3+</div>
                    <div class="jss-heading-sub">H3, H4, H5, H6 — máximo Level 3</div>
                </div>
                <select class="jss-level-select js-h3-level">
                    {{#each ../levelOptions}}
                    <option value="{{this.value}}" {{#if (eq this.value ../h3Level)}}selected{{/if}}>{{this.label}}</option>
                    {{/each}}
                </select>
            </div>

            <div class="jss-section-label"><i class="fas fa-palette"></i> Opções de Apresentação</div>

            {{!-- Title Options --}}
            <div class="jss-option-row">
                <span class="jss-badge jss-bopt">Título</span>
                <div class="jss-heading-info">
                    <div class="jss-heading-title">Título no topo de cada página</div>
                    <div class="jss-heading-sub">Nome em destaque, bold e sublinhado</div>
                </div>
                <div class="jss-option-controls">
                    <div class="jss-check-row">
                        <input type="checkbox" class="js-show-title" id="jss-chk-st" {{#if showTitle}}checked{{/if}}>
                        <label for="jss-chk-st">Mostrar</label>
                        <input type="color" class="jss-color-pick js-title-color" value="{{titleColor}}">
                    </div>
                    <div class="jss-title-preview js-title-preview" style="color:{{titleColor}};">Exemplo de Título</div>
                </div>
            </div>

            {{!-- Display Page Title --}}
            <div class="jss-option-row">
                <span class="jss-badge jss-bpin"><i class="fas fa-thumbtack"></i></span>
                <div class="jss-heading-info">
                    <div class="jss-heading-title">Display Page Title</div>
                    <div class="jss-heading-sub">Mostrar título nativo da página (padrão: NÃO)</div>
                </div>
                <div class="jss-check-row">
                    <input type="checkbox" class="js-display-page-title" id="jss-chk-dpt" {{#if displayPageTitle}}checked{{/if}}>
                    <label for="jss-chk-dpt">Ativar</label>
                </div>
            </div>

            {{!-- Info Box --}}
            <div class="jss-info-box">
                <strong>Como funciona:</strong><br>
                Criado um <strong class="jss-hl-purple">novo journal</strong> com sufixo "(Split)".<br>
                Cada heading vira uma <strong class="jss-hl-blue">nova página</strong> com o level configurado.<br>
                Seções <strong class="jss-hl-green">sem texto</strong> (só imagens/espaços) são unidas à próxima com conteúdo.<br>
                Journal original <strong class="jss-hl-orange">não é modificado</strong>.
            </div>
        </div>

    </div>

    {{!-- Footer --}}
    <div class="jss-footer">
        <div class="jss-status">
            {{#if hasSelection}}
                {{pageCount}} página(s) encontrada(s)
            {{else}}
                Selecione um journal para começar
            {{/if}}
        </div>
        <button type="button" data-action="split" class="jss-btn jss-btn-ok" {{#unless hasSelection}}disabled{{/unless}}>
            <i class="fas fa-cut"></i> Criar Journal Split
        </button>
    </div>

</div>
