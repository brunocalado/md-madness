{
  "id": "md-madness",
  "title": "MD Madness",
  "version": "0.0.4",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "Madness"
    }
  ],
  "esmodules": [
    "scripts/main.js"
  ],
  "styles": [
    "styles/madness.css"
  ],
  "description": "A customized module for V13 automation.",
  "packs": [
    {
      "label": "Names",
      "name": "names",
      "path": "packs/names",
      "type": "RollTable",
      "flags": {},
      "ownership": {
        "PLAYER": "OBSERVER",
        "ASSISTANT": "OWNER"
      }
    },
    {
      "label": "Macros",
      "type": "Macro",
      "name": "macros",
      "path": "packs/macros",
      "ownership": {
        "PLAYER": "NONE",
        "ASSISTANT": "OWNER"
      },
      "flags": {}
    }    
  ],

  "packFolders": [
    {
      "name": "Madness!",
      "sorting": "a",
      "color": "#3e0a66",
      "packs": [        
        "names",
        "macros"
      ],
      "folders": []
    }
  ],  
  
  "url": "https://github.com/brunocalado/md-madness",
  "manifest": "https://raw.githubusercontent.com/brunocalado/md-madness/refs/heads/main/module.json",
  "download": "https://codeload.github.com/brunocalado/md-madness/zip/main"
}